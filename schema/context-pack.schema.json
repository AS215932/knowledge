{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AS215932 Knowledge Context Pack",
  "type": "object",
  "required": ["id", "role", "generated_at", "knowledge_snapshot", "retrieval_version", "policy_version", "token_budget", "max_chars", "risk_level", "task", "sections", "included_refs", "excluded_refs", "policy_decision", "unresolved_questions"],
  "properties": {
    "id": {"type": "string", "pattern": "^ctx_[a-f0-9]{32}$"},
    "task_id": {"type": ["string", "null"]},
    "role": {"type": "string"},
    "generated_at": {"type": "string"},
    "knowledge_snapshot": {"type": "string"},
    "retrieval_version": {"type": "string"},
    "policy_version": {"type": "string"},
    "token_budget": {"type": "integer", "minimum": 1},
    "max_chars": {"type": "integer", "minimum": 1},
    "risk_level": {"type": "string"},
    "task": {"type": "object"},
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "body", "refs"],
        "properties": {
          "name": {"type": "string"},
          "body": {"type": "string"},
          "refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "included_refs": {"type": "array", "items": {"type": "object"}},
    "excluded_refs": {"type": "array", "items": {"type": "object"}},
    "policy_decision": {"type": "object"},
    "unresolved_questions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
