{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AS215932 OKF Concept Frontmatter",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {"type": "string", "minLength": 1},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "resource": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "timestamp": {"type": "string"},
    "truth_owner": {"enum": ["repo", "okf", "observed", "external", "derived"]},
    "authority": {"enum": ["canonical", "advisory", "evidence", "stale", "disputed"]},
    "source_refs": {"type": "array"},
    "last_verified_at": {"type": "string"},
    "confidence": {"enum": ["high", "medium", "low"]},
    "dispute_policy": {"enum": ["repo_wins", "okf_wins", "adjudicate", "evidence_only"]},
    "review_status": {"type": "string"},
    "quality_score": {"type": "number"},
    "enrichment": {"type": "object"},
    "enrichment_json": {"type": "string"},
    "observed_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "collection_profile": {"type": "string"},
    "observation_source": {"type": "string"},
    "observation_status": {"type": "string"},
    "payload_json": {"type": "string"}
  },
  "additionalProperties": true
}
